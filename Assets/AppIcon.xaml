<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 
        App Icon for WallpaperDestop
        Style: Modern Fluent / GitHub Dark inspired
        Concept: High-quality landscape (mountains) with a lock (Lock Screen)
    -->
    <DrawingImage x:Key="AppIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Background (Rounded Square) -->
                <GeometryDrawing Brush="#0D1117">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,256,256" RadiusX="48" RadiusY="48"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                
                <!-- Landscape: Background Mountain (Lighter Blue/Muted) -->
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <SolidColorBrush Color="#58A6FF" Opacity="0.4"/>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M40,180 L90,110 L140,180 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                
                <!-- Landscape: Foreground Mountain (Main Accent Blue) -->
                <GeometryDrawing Brush="#58A6FF">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M80,180 L160,70 L240,180 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                
                <!-- Sun/Moon (Foreground White) -->
                <GeometryDrawing Brush="#E6EDF3">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="180,70" RadiusX="22" RadiusY="22"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                
                <!-- Lock Container (Bottom Right Corner) -->
                <GeometryDrawing Brush="#161B22">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="140,140,90,90" RadiusX="16" RadiusY="16"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                
                <!-- Lock Icon (Accent Blue) -->
                <DrawingGroup>
                    <!-- Shackle (Top part) -->
                    <GeometryDrawing Brush="#58A6FF">
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M173,185 C173,178 178,173 185,173 C192,173 197,178 197,185 L197,188 L173,188 Z"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <!-- Body (Bottom part) -->
                    <GeometryDrawing Brush="#58A6FF">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="170,188,30,22" RadiusX="4" RadiusY="4"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
