<Window x:Class="WallpaperDestop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:WallpaperDestop.Converters"
        xmlns:views="clr-namespace:WallpaperDestop.Views"
        mc:Ignorable="d"
        Title="WallpaperDestop - Lock Screen Manager"
        Icon="{StaticResource AppIcon}"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        Foreground="#E6EDF3">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <converters:HexColorToBrushConverter x:Key="HexToBrush" />
    </Window.Resources>

    <Grid>
        <!-- ═══ Main Content ═══ -->
        <Grid Visibility="{Binding IsSettingsOpen, Converter={StaticResource InverseBoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Top Bar ── -->
            <Border Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- App Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource AppIcon}" Width="32" Height="32" 
                               VerticalAlignment="Center" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="WallpaperDestop" FontSize="20" FontWeight="SemiBold" Foreground="#E6EDF3" />
                            <TextBlock Text="Lock Screen Wallpaper Manager" FontSize="11" Foreground="#8B949E" Margin="0,-2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Load Photos -->
                        <Button Command="{Binding LoadPhotosCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="Load Photos" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Random Lock Screen -->
                        <Button Command="{Binding RandomLockScreenCommand}"
                                Style="{StaticResource AccentButton}"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="Random Wallpaper" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Settings -->
                        <Button Command="{Binding OpenSettingsCommand}"
                                Style="{StaticResource SubtleButton}"
                                ToolTip="Settings">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Photo Gallery ── -->
            <Grid Grid.Row="1">

                <!-- Loading Overlay -->
                <Border Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                     Foreground="#58A6FF" Background="#21262D" BorderThickness="0" />
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#8B949E"
                                   FontSize="13" Margin="0,12,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasNoPhotos, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                               Foreground="#30363D" HorizontalAlignment="Center" />
                    <TextBlock Text="No photos loaded yet" FontSize="16" Foreground="#8B949E"
                               HorizontalAlignment="Center" Margin="0,12,0,4" />
                    <TextBlock Text="Click 'Load Photos' to fetch wallpapers from Unsplash"
                               FontSize="12" Foreground="#484F58" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Photo Grid (WrapPanel inside ScrollViewer) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="16">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Photos ItemsControl -->
                        <ItemsControl ItemsSource="{Binding Photos}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Photo Card -->
                                    <Border Width="320" Height="200" Margin="8" CornerRadius="8"
                                            Background="{Binding Color, Converter={StaticResource HexToBrush}}"
                                            Cursor="Hand"
                                            ClipToBounds="True">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.4" />
                                        </Border.Effect>
                                        <Grid>
                                            <!-- High-Quality Thumbnail - Tối ưu cho preview UI -->
                                            <Image Source="{Binding Urls.HighQualityPreview, IsAsync=True}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />

                                            <!-- Gradient Overlay (bottom) -->
                                            <Border VerticalAlignment="Bottom">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#00000000" Offset="0" />
                                                        <GradientStop Color="#CC000000" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Grid Margin="12,24,12,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Photographer Name -->
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                                                        <TextBlock Text="{Binding DisplayDescription}"
                                                                   FontSize="11" Foreground="#C9D1D9"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="200" />
                                                        <TextBlock FontSize="10" Foreground="#8B949E" Margin="0,2,0,0">
                                                            <Run Text="by " /><Run Text="{Binding User.Name, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Set as Lock Screen Button -->
                                                    <Button Grid.Column="1"
                                                            Command="{Binding DataContext.SetLockScreenCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource CardButton}"
                                                            ToolTip="Set as Lock Screen">
                                                        <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="16" Foreground="White" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Load More Button -->
                        <Button Command="{Binding LoadMoreCommand}"
                                Style="{StaticResource AccentButton}"
                                Margin="0,24,0,0"
                                MinWidth="200"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding LoadMoreButtonText}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── Status Bar ── -->
            <Border Grid.Row="2" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,1,0,0"
                    Padding="24,8">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#8B949E"
                               VerticalAlignment="Center" />
                    <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="#484F58"
                               VerticalAlignment="Center">
                        <Run Text="Powered by Unsplash" />
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ Settings Overlay ═══ -->
        <Grid Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVis}}">
            <views:SettingsView DataContext="{Binding SettingsViewModel}" />

            <!-- Close button for settings -->
            <Button Command="{Binding CloseSettingsCommand}"
                    Style="{StaticResource SubtleButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,20,24,0" ToolTip="Close Settings">
                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="20" />
            </Button>
        </Grid>
    </Grid>
</Window>
