<UserControl x:Class="WallpaperDestop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:WallpaperDestop.Converters"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1100"
             Background="#0D1117">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Dark overlay background -->
        <Border Background="#0D1117" />

        <!-- Centered settings card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="520" Width="520"
                Background="#161B22" CornerRadius="12"
                BorderBrush="#30363D" BorderThickness="1"
                Padding="32,28">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="4" Opacity="0.5" />
            </Border.Effect>

            <StackPanel>
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                               Foreground="#58A6FF" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" Foreground="#E6EDF3" />
                </StackPanel>

                <!-- ── Unsplash API Key ── -->
                <TextBlock Text="UNSPLASH API KEY" FontSize="11" FontWeight="SemiBold"
                           Foreground="#8B949E" Margin="0,0,0,6" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Tag="Paste your Unsplash Access Key..." />
                    <!-- Validation icon -->
                    <TextBlock Grid.Column="1" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                               FontSize="16" Foreground="#3FB950"
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding IsApiKeyValid, Converter={StaticResource BoolToVis}}" />
                </Grid>
                <TextBlock FontSize="11" Foreground="#484F58" Margin="0,4,0,0" TextWrapping="Wrap">
                    <Run Text="Get your free API key at " />
                    <Hyperlink NavigateUri="https://unsplash.com/developers"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="#58A6FF" TextDecorations="None">
                        unsplash.com/developers
                    </Hyperlink>
                </TextBlock>

                <!-- Separator -->
                <Border Height="1" Background="#21262D" Margin="0,20,0,20" />

                <!-- ── Search Query ── -->
                <TextBlock Text="DEFAULT SEARCH QUERY" FontSize="11" FontWeight="SemiBold"
                           Foreground="#8B949E" Margin="0,0,0,6" />
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"
                         Tag="e.g. nature, city, abstract (leave empty for editorial)" />
                <TextBlock Text="Filter photos by topic. Leave empty for curated editorial picks."
                           FontSize="11" Foreground="#484F58" Margin="0,4,0,0" />

                <!-- Separator -->
                <Border Height="1" Background="#21262D" Margin="0,20,0,20" />

                <!-- ── Photo Count ── -->
                <TextBlock Text="GALLERY PHOTO COUNT" FontSize="11" FontWeight="SemiBold"
                           Foreground="#8B949E" Margin="0,0,0,6" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0"
                            Value="{Binding PhotoCount}"
                            Minimum="5" Maximum="30"
                            TickFrequency="5" IsSnapToTickEnabled="False"
                            VerticalAlignment="Center"
                            Foreground="#58A6FF" />
                    <Border Grid.Column="1" Background="#21262D" CornerRadius="4"
                            Padding="10,4" Margin="12,0,0,0">
                        <TextBlock Text="{Binding PhotoCount}" FontSize="13" Foreground="#E6EDF3"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" MinWidth="20"
                                   TextAlignment="Center" />
                    </Border>
                </Grid>

                <!-- Separator -->
                <Border Height="1" Background="#21262D" Margin="0,20,0,20" />

                <!-- ── Start with Windows ── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Start with Windows" FontSize="14" Foreground="#E6EDF3" />
                        <TextBlock Text="Automatically change lock screen on startup (runs silently in background)"
                                   FontSize="11" Foreground="#484F58" TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                    <CheckBox Grid.Column="1"
                              IsChecked="{Binding StartWithWindows}"
                              VerticalAlignment="Center"
                              Style="{StaticResource ToggleCheckBox}" />
                </Grid>

                <!-- Separator -->
                <Border Height="1" Background="#21262D" Margin="0,20,0,20" />

                <!-- ── Save Button ── -->
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Padding="0,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Save Settings" FontSize="14" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Save Status -->
                <TextBlock Text="{Binding SaveStatus}" FontSize="12" Foreground="#3FB950"
                           HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
